# Copy this file to .env and fill in the values

# MongoDB connection string
# Local:  mongodb://localhost:27017/police_reports
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/police_reports
MONGO_URI=mongodb://localhost:27017/police_reports

# Server port
PORT=4000

# Allowed frontend origin (for CORS in production)
# Dev: http://localhost:3000
# Prod: https://yourdomain.com
FRONTEND_URL=http://localhost:3000
